{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": [
      "chrome",
      "node"
    ],
    "noImplicitAny": false
  },
  "include": [
    "src/**/*.js",
    "vite.config.js"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
