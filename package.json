{
  "name": "siakad-x",
  "version": "0.2.0",
  "description": "Ekstensi browser untuk modernisasi portal akademik Universitas Andalas",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "eslint src/**/*.js tests/**/*.js vite.config.js",
    "lint:fix": "eslint src/**/*.js tests/**/*.js vite.config.js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"tests/**/*.{js,html}\" \"*.{js,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.2",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "universitas-andalas",
    "attendance-unand",
    "akademik"
  ],
  "license": "MIT"
}
